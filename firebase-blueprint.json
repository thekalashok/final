{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "age": { "type": "number" },
        "mobile": { "type": "string" },
        "addresses": { "type": "array", "items": { "type": "string" } },
        "created_date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "created_date"]
    },
    "Product": {
      "title": "Product",
      "description": "Crochet product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "cost_price": { "type": "number" },
        "stock": { "type": "number" },
        "image_url": { "type": "string" },
        "sku": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "out_of_stock"] },
        "created_date": { "type": "string", "format": "date-time" },
        "updated_date": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" }
      },
      "required": ["id", "name", "price", "category", "status"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer details for admin use",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "created_date": { "type": "string", "format": "date-time" },
        "updated_date": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" }
      },
      "required": ["id", "name", "phone"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "order_number": { "type": "string" },
        "customer_name": { "type": "string" },
        "customer_phone": { "type": "string" },
        "customer_address": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "payment_method": { "type": "string", "enum": ["cash", "UPI"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "processing", "completed", "cancelled"] },
        "created_date": { "type": "string", "format": "date-time" },
        "updated_date": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" }
      },
      "required": ["id", "order_number", "customer_name", "total", "status"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "products": { "schema": "Product", "description": "Product catalog" },
    "customers": { "schema": "Customer", "description": "Customer database" },
    "orders": { "schema": "Order", "description": "Orders list" },
    "categories": { "schema": "Category", "description": "Available product categories" }
  }
}
